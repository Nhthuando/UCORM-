generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ai_replies {
  id                                            String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  review_id                                     String
  type                                          String
  content                                       String
  created_at                                    DateTime? @default(now()) @db.Timestamptz(6)
  reviews_ai_replies_review_idToreviews         reviews   @relation("ai_replies_review_idToreviews", fields: [review_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews_reviews_approved_reply_idToai_replies reviews[] @relation("reviews_approved_reply_idToai_replies")
}

model places {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  google_place_id String
  name            String?
  user_id         String
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  users           users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews         reviews[]

  @@unique([google_place_id, user_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id                                               String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  place_id                                         String
  google_id                                        String
  author_name                                      String?
  rating                                           Int?
  text                                             String?
  published_at                                     DateTime?    @db.Timestamptz(6)
  status                                           String?      @default("PENDING")
  approved_reply_id                                String?
  created_at                                       DateTime?    @default(now()) @db.Timestamptz(6)
  ai_replies_ai_replies_review_idToreviews         ai_replies[] @relation("ai_replies_review_idToreviews")
  ai_replies_reviews_approved_reply_idToai_replies ai_replies?  @relation("reviews_approved_reply_idToai_replies", fields: [approved_reply_id], references: [id], onUpdate: NoAction, map: "fk_approved_reply")
  places                                           places       @relation(fields: [place_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([google_id, place_id])
}

model users {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  email      String    @unique
  password   String
  name       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  places     places[]
}
